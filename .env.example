# ══════════════════════════════════════════════════════════════
#   AI CONTENT + AFFILIATE SYSTEM — CONFIG
#   Copy file này thành .env rồi điền key của bạn
# ══════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────┐
# │  CHỌN 1 TRONG 3 AI PROVIDER (ưu tiên từ trên xuống)        │
# └─────────────────────────────────────────────────────────────┘

# OPTION 1: Google Gemini — MIỄN PHÍ, không cần thẻ tín dụng
#   Lấy tại: https://aistudio.google.com/app/apikey
#   Giới hạn free: 250 req/ngày (Flash) | 1000 req/ngày (Flash-Lite)
GEMINI_API_KEY=your_gemini_api_key_here

# OPTION 2: Groq — MIỄN PHÍ, siêu nhanh (Llama 70B)
#   Lấy tại: https://console.groq.com/keys
#   Giới hạn free: 14,400 req/ngày, 30,000 tokens/phút
# GROQ_API_KEY=your_groq_api_key_here

# OPTION 3: OpenRouter — có model miễn phí
#   Lấy tại: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_key_here

# OPTION 4: Anthropic Claude — TRẢ PHÍ, chất lượng tốt nhất
#   Lấy tại: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ┌─────────────────────────────────────────────────────────────┐
# │  WORDPRESS (để trống nếu chưa có, bài lưu vào data/articles)│
# └─────────────────────────────────────────────────────────────┘
WP_SITE_URL=https://yoursite.com
WP_USERNAME=your_wp_username
# Tạo tại: WP Admin → Users → Application Passwords
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ┌─────────────────────────────────────────────────────────────┐
# │  AFFILIATE PROGRAMS (tùy chọn)                              │
# └─────────────────────────────────────────────────────────────┘
# Amazon Associates: https://affiliate-program.amazon.com/
AMAZON_AFFILIATE_TAG=yourtag-20

# ClickBank: https://accounts.clickbank.com/
# CLICKBANK_ID=yourclickbankid

# ShareASale: https://www.shareasale.com/
# SHAREASALE_ID=your_shareasale_id

# ┌─────────────────────────────────────────────────────────────┐
# │  SERP API — phân tích đối thủ (tùy chọn, free 100/tháng)   │
# └─────────────────────────────────────────────────────────────┘
# Lấy tại: https://serpapi.com/
# SERP_API_KEY=your_serp_api_key
